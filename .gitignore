# Large data files (Platsbanken JSONL zips and extracted files)
data/raw/*.jsonl.zip
data/raw/*.jsonl
data/raw/*.zip

# Processed data (regenerated by pipeline)
data/processed/

# Keep directory structure
!data/raw/.gitkeep
!data/processed/.gitkeep

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
*.egg-info/

# macOS
.DS_Store

# IDE
.vscode/
.idea/

# LaTeX build artifacts
*.aux
*.bbl
*.blg
*.log
*.out
*.fls
*.fdb_latexmk
*.synctex.gz
*.pdf
!figures/*.pdf
!onepager/*.pdf

# Presentations (local only, not public by default)
presentation/

# Media materials (drafts, op-eds — local only)
media/

# Internal working files (not for public repo)
SESSION_PICKUP.md
SESSION_SUMMARY.md
PICKUP_PROMPT.md
correspondence/
notes/
input/
replication_stata.log

# Data packages (shared separately with collaborators)
mona_package/
mona_package.zip
dst_package/
dst_package.zip

# MONA output (aggregated results from restricted register data)
data/mona/

# Old script archives and MONA zip transfers
src/Arkiv.zip
src/*.py.zip

# LaTeX TOC
*.toc

# Sensitive
.env
*.env
