*** HARMONIZE THE TWO DATASETS ***

*(same variable names and formats, years observed)

*Claude
use "${data_raw}/postings_ssyk4_monthly_claude_original.dta", clear
	gen year = substr(year_month,1,4)
	destring year, replace
	keep if year>=2020 & year<=2024
	rename n_ads ads_claude
	count // 23367
	save "${data_raw}/postings_ssyk4_monthly_claude.dta", replace

*Erik
use "${data_raw}/ssyk2012_4_month_erik_original.dta", clear	
	keep if year>=2020 & year<=2024
	tostring year, gen(year_str)
	tostring month, gen(month_str)
	replace month_str = "0" + month_str if month<=9 & month>=1
	gen year_month = year_str + "-" + month_str
	gen ssyk4 = ssyk2012_4
	rename ads ads_erik
	count // 23425
	save "${data_raw}/ssyk2012_4_month_erik.dta", replace
	

	
*** MERGE AND COMPARE ***

*Open Claude data	
use "${data_raw}/postings_ssyk4_monthly_claude.dta", clear	
